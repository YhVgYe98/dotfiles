# proxy setting
# wsl need mirror net mode
function clashon() {
    local proxy_ip="127.0.0.1"
    local proxy_port="7890"
    export ALL_PROXY=http://${proxy_ip}:${proxy_port}
    export HTTP_PROXY=http://${proxy_ip}:${proxy_port}
    export HTTPS_PROXY=http://${proxy_ip}:${proxy_port}
    export all_proxy=http://${proxy_ip}:${proxy_port}
    export http_proxy=http://${proxy_ip}:${proxy_port}
    export https_proxy=http://${proxy_ip}:${proxy_port}
    export NO_PROXY=127.0.0.1,localhost,::1
    export no_proxy=127.0.0.1,localhost,::1
    echo "Proxy set to http://${proxy_ip}:${proxy_port}"
}
function clashoff() {
    unset HTTP_PROXY HTTPS_PROXY ALL_PROXY http_proxy https_proxy all_proxy NO_PROXY no_proxy
    echo "Proxy settings cleared."
}

alias vim='nvim'
alias ariadl='aria2c --auto-file-renaming --no-conf -x 16'
alias tmuxa='tmux new-session -A -s main'

export GPG_TTY=$(tty)

export GOPROXY=https://goproxy.cn,direct
